# kintoneのベースURL設定
# 複数ドメインを設定する場合は、KINTONE_BASE_URL_1, KINTONE_BASE_URL_2 のように末尾に数字（サフィックス）をつけます。
# サフィックスなしの場合はデフォルトのドメインとして扱われます。

# --- 設定 1 ---
KINTONE_BASE_URL_1=https://sample.cybozu.com
# パターン1: APIトークン（複数アプリの場合はカンマ区切り、または全アプリにアクセス可能なトークン）
KINTONE_API_TOKEN_1=
# パターン2: パスワード認証 (APIトークンが未設定の場合に使用されます)
KINTONE_USERNAME_1=username
KINTONE_PASSWORD_1=password

# --- 設定 2 ---
# KINTONE_BASE_URL_2=https://example.cybozu.com
# KINTONE_API_TOKEN_2=
# KINTONE_USERNAME_2=
# KINTONE_PASSWORD_2=